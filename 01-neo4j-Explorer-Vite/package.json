{
  "name": "shadcn-admin",
  "private": false,
  "version": "2.2.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,yellow \"vite\" \"npm run dev:server\"",
    "dev:full": "concurrently -n db,fe,be -c green,cyan,yellow \"npm run db:start -- --wait\" \"vite\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "db:start": "docker compose up -d neo4j && echo 'Neo4j: http://localhost:7474'",
    "db:stop": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d neo4j",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "knip": "knip",
    "create-app": "node scripts/create-app/dist/index.js"
  },
